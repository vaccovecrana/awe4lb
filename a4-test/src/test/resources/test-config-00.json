{
  "id": "test-config-00",
  "description": "Test configuration",
  "servers": [
    {
      "id": "https-txt",
      "addr": {
        "host": "0.0.0.0",
        "port": 8443
      },
      "match": [
        {
          "op": {
            "sni": {
              "equals": "momo.localhost"
            }
          },
          "pool": {
            "hosts": [
              {
                "addr": {
                  "host": "172.16.4.58",
                  "port": 8080
                }
              }
            ]
          },
          "healthCheck": {
            "intervalMs": 900000,
            "timeoutMs": 800000
          },
          "tls": {
            "certPath": "./src/test/resources/certs/awe4lb.pem",
            "keyPath": "./src/test/resources/certs/awe4lb.key"
          }
        },
        {
          "op": {
            "sni": {
              "equals": "sdr.localhost"
            }
          },
          "pool": {
            "hosts": [
              {
                "addr": {
                  "host": "172.16.4.58",
                  "port": 8096
                }
              }
            ]
          },
          "tls": {
            "certPath": "./src/test/resources/certs/awe4lb.pem",
            "keyPath": "./src/test/resources/certs/awe4lb.key"
          }
        }
      ],
      "tls": {
        "ciphers": [
          "TLS_AES_128_GCM_SHA256"
        ]
      }
    }
  ]
}